# Site URL path (Vite `base`). Default "/" for Vercel. Use /portfolio/ only for GitHub Pages subpath.
# VITE_BASE_PATH=/

# ========== Vercel (Production) — add in Dashboard → Environment Variables ==========
#
# Primary (recommended): server route /api/contact submits from Vercel (not the browser), which usually
# fixes Web3Forms failing on *.vercel.app. Use the SAME access key UUID as on web3forms.com.
# WEB3FORMS_ACCESS_KEY=
#
# Backup if Web3Forms still rejects: https://resend.com — free tier. Do NOT prefix with VITE_.
# RESEND_API_KEY=
# MAIL_TO=you@example.com
# MAIL_FROM=Portfolio <onboarding@resend.dev>
#
# Optional: client-side fallback (must start with VITE_ to exist in the browser bundle).
# VITE_WEB3FORMS_ACCESS_KEY=
# VITE_EMAILJS_PUBLIC_KEY=
# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=
#
# Enable Production + Preview, then Redeploy.

# ========== Local dev (npm run dev) — copy to .env ==========
# Uses browser Web3Forms / EmailJS; set at least one VITE_* line below or WEB3FORMS_ACCESS_KEY is ignored client-side.

# --- Web3Forms (client fallback / local) ---
# VITE_WEB3FORMS_ACCESS_KEY=

# --- EmailJS (optional client fallback) ---
# VITE_EMAILJS_PUBLIC_KEY=
# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=
