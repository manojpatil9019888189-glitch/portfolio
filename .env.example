# Site URL path (Vite `base`). Default "/" for Vercel and `npm run dev`. Use /portfolio/ only for GitHub Pages subpath.
# VITE_BASE_PATH=/

# --- Vercel / Netlify / any host ---
# Copy the variables you need into the dashboard (not into git). Names MUST start with VITE_.
# Vercel: Project → Settings → Environment Variables → add each key for Production (and Preview if you want).
# Redeploy after saving, or the new values are not in the built app.

# --- Option A: EmailJS (recommended) — you design the email; no “Hello / new form submitted” text.
# Sign up at https://www.emailjs.com → Email Services (e.g. Gmail) → Email Templates.
# Template subject: {{subject}}
# Template body (example — only what visitors send):
#   Name: {{from_name}}
#   Email: {{from_email}}
#
#   {{message}}
# Account → API keys → Public Key
# VITE_EMAILJS_PUBLIC_KEY=
# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=

# --- Option B: Web3Forms — easy but adds fixed intro text in the notification email.
# https://web3forms.com
# VITE_WEB3FORMS_ACCESS_KEY=
